# Models directory (host path, mounted as /models inside container)
MODELS_DIR=./models

# LLM
LLM_MODEL_PATH=/models/llm/model.gguf
LLM_SYSTEM_PROMPT=You are a helpful AI assistant running on a Raspberry Pi. Be concise and clear.
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_N_CTX=4096 # Context window
LLM_N_THREADS=3 # CPU threads


# STT
WHISPER_MODEL_SIZE=base # tiny | base | small  (auto-downloads on first run)
WHISPER_LANGUAGE=en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8 # int8 is the right choice for RPI 4 CPU


# Wake word
WAKE_WORD_MODEL_PATH=/models/wakeword/model.onnx
WAKE_WORD_THRESHOLD=0.5 # (sensitivity)
WAKE_WORD_FRAMEWORK=onnx


# TTS
PIPER_MODEL_PATH=/models/tts/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=/models/tts/en_US-lessac-medium.onnx.json
PIPER_SPEAKER_ID=-1


# Audio
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_SIZE=1280 # (1280 = 80ms @ 16kHz)
AUDIO_INPUT_DEVICE=-1
AUDIO_OUTPUT_DEVICE=-1


# Pipeline

# Seconds of consecutive silence before recording stops
SILENCE_DURATION=1.5

# Maximum recording length (safety cap)
MAX_RECORD_SECONDS=15.0

# RMS energy below this = silence (tune for your room noise floor)
SILENCE_THRESHOLD=0.02

# Confirmation beep after wake word is detected
AUDIO_VOLUME=1.0         
CONFIRMATION_BEEP=true
BEEP_FREQUENCY=880.0
BEEP_DURATION=0.15

# Agent settings
AGENT_ENABLED=true
AGENT_MAX_ITERATIONS=5
AGENT_SPEAK_INTERMEDIATE=true
